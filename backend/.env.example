# ============================================================
# VARIABLES DE ENTORNO - DinoDentis Backend
# Copia este archivo como .env y completa los valores
# ============================================================

# Puerto del servidor (default: 3001)
PORT=3001

# URL del frontend para CORS
FRONTEND_URL=http://localhost:5173

# Ruta de la base de datos SQLite
DB_PATH=./data/dinodentis.db

# ── Agente IA ────────────────────────────────────────────────
# Obtén tu clave en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (opcional) ─────────────────────────────────────────
# Si no se configuran, las citas igual se guardan pero no se
# envían emails. No afecta el funcionamiento del formulario.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_app
DOCTOR_EMAIL=doctora@dinodentis.com
